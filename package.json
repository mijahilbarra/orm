{
  "name": "orm",
  "version": "0.1.0",
  "description": "ORM Firestore con Zod para frontend y backend",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./frontend": {
      "types": "./dist/frontend/index.d.ts",
      "default": "./dist/frontend/index.js"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "default": "./dist/backend/index.js"
    },
    "./firestore": {
      "types": "./dist/firestore/index.d.ts",
      "default": "./dist/firestore/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "firebase": "^10.0.0",
    "firebase-admin": "^12.0.0"
  },
  "peerDependenciesMeta": {
    "firebase": {
      "optional": true
    },
    "firebase-admin": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "firebase": "^10.14.1",
    "firebase-admin": "^12.7.0",
    "typescript": "^5.4.0"
  }
}
